# DB context snapshot refresh variables (do not commit real secrets)
#
# Usage:
#   source .env
#   python3 scripts/db_context_snapshot.py --refresh \
#     --master-connection "$DB_CONTEXT_MASTER_CONNECTION" \
#     --process-connection "process-a::$PROCESS_A_CONNECTION"

# Required: master database connection string
DB_CONTEXT_MASTER_CONNECTION=

# Required: first process database connection string
PROCESS_A_CONNECTION=

# Optional: additional process database connection strings
# PROCESS_B_CONNECTION=
# PROCESS_C_CONNECTION=
